# Notion API 설정
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ITEMS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 앱 기본 URL (개발: http://localhost:3002, 프로덕션: https://your-domain.com)
NEXT_PUBLIC_BASE_URL=http://localhost:3002

# 어드민 페이지 접근 비밀번호
ADMIN_PASSWORD=your_admin_password

# 발행인 정보 (견적서 공개 조회 페이지에 표시)
NEXT_PUBLIC_ISSUER_NAME=발행인 회사명
NEXT_PUBLIC_ISSUER_CONTACT=010-0000-0000
NEXT_PUBLIC_ISSUER_ADDRESS=서울시 강남구
